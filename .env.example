# Graphiti MCP Server 配置範例
# ============================
# 此文件列出所有被 src/config.py 實際讀取的環境變數。
# 複製為 .env 後修改對應的值即可：cp .env.example .env

# ======================
# Neo4j 圖資料庫（必填）
# ======================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password   # ← 必須修改
NEO4J_DATABASE=neo4j

# ======================
# Ollama LLM 模型
# ======================
# 主模型：用於實體提取、邊提取等複雜任務
# 推薦 qwen2.5:3b（速度與穩定性最佳平衡，~2s/call）
# 可選 qwen2.5:7b（效果更好但慢 5-10 倍）
OLLAMA_MODEL=qwen2.5:3b

# 小模型：用於去重判斷、摘要生成、時間解析等簡單任務
# graphiti-core pipeline 會自動在簡單任務使用小模型
# 未設定時自動回退為主模型。當有更快且穩定的小模型時可替換。
# 注意：qwen2.5:1.5b 結構化 JSON 輸出不穩定（成功率 33%），不建議使用
OLLAMA_SMALL_MODEL=qwen2.5:3b

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TEMPERATURE=0.1
# 強制 LLM 輸出語言（如 "Traditional Chinese"），未設定時由模型自行決定
OLLAMA_TARGET_LANGUAGE=Traditional Chinese

# ======================
# Ollama 嵌入模型
# ======================
# 用於向量搜尋，維度必須與模型一致
OLLAMA_EMBEDDING_MODEL=nomic-embed-text:v1.5
OLLAMA_EMBEDDING_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_DIMENSIONS=768

# ======================
# 伺服器設定
# ======================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_TRANSPORT=http

# ======================
# 日誌配置
# ======================
LOG_FILE=logs/graphiti_mcp_server.log
LOG_LEVEL=INFO
LOG_ROTATION_TYPE=time
LOG_ROTATION_INTERVAL=midnight
LOG_BACKUP_COUNT=30

# 第三方日誌級別覆蓋（JSON 格式，可選）
# GRAPHITI_LOG_THIRD_PARTY_LEVELS={"neo4j":"DEBUG"}

# ======================
# 記憶效能配置
# ======================
# 觸發智慧切分的字元數閾值（超過此值自動分段處理）
GRAPHITI_CHUNK_THRESHOLD=800

# 切分後每段最大字元數
GRAPHITI_MAX_CHUNK_SIZE=600

# Graphiti 內部最大並行協程數（本地 LLM 建議 3-5，雲端可調高）
GRAPHITI_MAX_COROUTINES=5

# 是否預設使用背景處理模式（true 時 add_memory_simple 立即返回）
GRAPHITI_DEFAULT_BACKGROUND=false

# ======================
# Graphiti 進階設定
# ======================
SEARCH_LIMIT=20
ENABLE_DEDUPLICATION=true
PYDANTIC_VALIDATION_FIXES=true
COSINE_SIMILARITY_THRESHOLD=0.8

# ======================
# 重要性追蹤與智慧遺忘
# ======================
# 啟用存取追蹤（搜尋後自動更新 access_count 和 last_accessed）
ENABLE_IMPORTANCE_TRACKING=true

# 重要性權重（影響搜尋結果排序）
IMPORTANCE_WEIGHT=0.1

# 過時記憶判定：超過此天數未存取的視為過時
STALE_DAYS_THRESHOLD=30

# 過時記憶判定：存取次數低於此值的才列入
STALE_MIN_ACCESS_COUNT=2

# ======================
# 其他
# ======================
# 關閉遙測
GRAPHITI_TELEMETRY_ENABLED=false
